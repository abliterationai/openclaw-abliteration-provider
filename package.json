{
  "name": "@abliteration-ai/openclaw-abliteration-provider",
  "version": "0.1.0",
  "description": "Abliteration.ai provider plugin for OpenClaw",
  "license": "MIT",
  "type": "module",
  "main": "./index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abliteration-ai/openclaw-abliteration-provider.git"
  },
  "bugs": {
    "url": "https://github.com/abliteration-ai/openclaw-abliteration-provider/issues"
  },
  "homepage": "https://github.com/abliteration-ai/openclaw-abliteration-provider#readme",
  "files": [
    "*.ts",
    "!*.test.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.24"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "openclaw": "^2026.4.24",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "providers": [
      "abliteration"
    ],
    "compat": {
      "pluginApi": ">=2026.4.24",
      "minGatewayVersion": "2026.4.24"
    },
    "build": {
      "openclawVersion": "2026.4.24",
      "pluginSdkVersion": "2026.4.24"
    }
  }
}
